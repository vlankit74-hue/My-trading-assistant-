# Copy this file to .env for local dev. On Render, do NOT upload this file —
# instead paste each key into the Render dashboard under
# Service > Environment > Environment Variables.

APP_ENV=production
LOG_LEVEL=INFO
# Set this to your Render frontend's URL once deployed, e.g.:
# CORS_ORIGINS=["https://your-frontend.onrender.com"]
CORS_ORIGINS=["http://localhost:5173"]

# --- Postgres ---
# Local dev: leave as-is if running Postgres via docker-compose.
# Render: create a Postgres instance on Render, then paste its
# "Internal Database URL" here (rewrite postgresql:// -> postgresql+asyncpg://)
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@db:5432/trading

# --- Redis ---
# Local dev: leave as-is if running Redis via docker-compose.
# Render: create a Redis instance on Render, then paste its Internal Redis URL here.
REDIS_URL=redis://redis:6379/0

# --- Twelve Data (Gold / XAU-USD) ---
TWELVEDATA_API_KEY=your_twelvedata_api_key

# --- Binance (BTC) ---
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# --- News (Finnhub is the sole source) ---
FINNHUB_API_KEY=your_finnhub_key

# --- AI Decision Layer ---
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4.1
# Not used while LLM_PROVIDER=openai, but kept here in case you switch later:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Scheduler ---
PRICE_REFRESH_INTERVAL_SEC=10
ANALYSIS_REFRESH_INTERVAL_SEC=120

# --- Own API protection ---
API_RATE_LIMIT=60/minute
INTERNAL_API_KEY=generate_a_random_secret_here
